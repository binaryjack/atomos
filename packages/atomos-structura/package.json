{
  "name": "@atomos-web/structura",
  "version": "2.3.23",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./webview": {
      "types": "./dist/webview/index.d.ts",
      "import": "./dist/webview/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "node scripts/gen-version.mjs && vite build",
    "build:webview-iife": "BUILD_TARGET=webview-iife vite build",
    "dev": "vite build --watch",
    "serve": "vite",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@atomos-web/prime": "workspace:*",
    "@atomos-web/prime-style": "workspace:*",
    "@atomos-web/structura-core": "workspace:*",
    "@atomos-web/structura-mcp": "workspace:*",
    "@binaryjack/formular.dev": "workspace:*"
  },
  "devDependencies": {
    "glob": "^10.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.0"
  }
}
